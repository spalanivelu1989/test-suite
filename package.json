{
  "name": "ai-ui-testing-tool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test:unit": "tsx --test \"src/**/*.test.ts\"",
    "test:db": "node --env-file-if-exists=.env.local --import tsx --test \"src/**/*.test.ts\"",
    "ci": "tsx bin/run-ci.ts",
    "render:html": "tsx bin/render-html.ts",
    "knowledge:migrate": "node --env-file-if-exists=.env.local --import tsx bin/knowledge-migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.152",
    "@anthropic-ai/sdk": "^0.99.0",
    "@chakra-ui/react": "^3.2.3",
    "@emotion/react": "^11.13.5",
    "@huggingface/transformers": "^4.2.0",
    "@types/three": "^0.184.1",
    "framer-motion": "^11.13.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.2",
    "pg": "^8.21.0",
    "playwright": "^1.60.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@playwright/cli": "^0.1.13",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "tsx": "^4.19.2"
  }
}
