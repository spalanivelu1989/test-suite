# Required: Anthropic API key for the Claude reasoning engine (DEP1, R6).
# The app reads this at runtime; without it, Claude-dependent stages fail clearly.
ANTHROPIC_API_KEY=

# Optional: override the Claude model used by the agent.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: PostgreSQL connection for the Knowledge Layer (Knowledge Platform
# Phase 1). When unset, the knowledge base is disabled and the pipeline runs
# "cold" — exactly as before (graceful degradation, Spec R4/N3). Production uses
# managed Neon (ADR-0001); local dev uses a trust-auth Postgres, e.g.:
#   KNOWLEDGE_DATABASE_URL=postgres://user@localhost:5433/knowledge
KNOWLEDGE_DATABASE_URL=

# Optional: Langfuse LLM observability/tracing. When BOTH keys are set, every run
# is traced (Discoverer/Designer/Tester agents + Reporter narrative) with model,
# token usage, and cost. When unset, tracing is disabled and the app runs exactly
# as before (graceful degradation, like KNOWLEDGE_DATABASE_URL above). Get keys
# from Langfuse → Settings → API Keys.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Data region/host: EU https://cloud.langfuse.com (default) · US
# https://us.cloud.langfuse.com · or a self-hosted URL.
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Optional: tag traces by environment (defaults to NODE_ENV). e.g. production, staging.
LANGFUSE_TRACING_ENVIRONMENT=

# Optional: form-login for a target app behind a username/password screen. When
# BOTH TARGET_USERNAME and TARGET_PASSWORD are set, the agents log in before
# exploring and every generated test runs already authenticated (via a saved
# Playwright storage state). When unset, the pipeline runs unauthenticated,
# exactly as before. Note: credentials are injected into the agent prompts (and
# therefore appear in Langfuse traces when tracing is enabled), and the saved
# session is written under .runs/<id>/.auth/ — keep these out of shared logs.
TARGET_USERNAME=
# ⚠️ IMPORTANT: this is a Next.js app, and Next loads .env files through
# dotenv-expand. That means a literal `$` (or `${...}`) in a value is treated as
# a variable reference and SILENTLY STRIPPED at load time — e.g. titanW$375
# becomes titanW before any agent ever sees it, producing a false "invalid email
# or password". Quotes do NOT help (dotenv-expand expands inside "" and '' alike).
# Escape every `$` as `\$` (and a literal backslash as `\\`):
#   TARGET_PASSWORD=titanW\$375
TARGET_PASSWORD=
# Optional: explicit login page. When unset, the agent logs in from the entry URL
# (most apps redirect an unauthenticated visit to their login form).
TARGET_LOGIN_URL=
# Optional: identity provider to pick when the login screen shows an IDP chooser
# (e.g. SAP BTP offers "Default Identity Provider" vs a corporate IDP). Set this to
# the provider's EXACT label so the agent doesn't guess or cycle providers (wrong-
# provider attempts can LOCK SSO accounts). An SAP S-user (id like S0001234567)
# normally uses "Default Identity Provider". When unset, the agent infers it from
# the username. Plain text — not a secret.
#   TARGET_IDP=Default Identity Provider
TARGET_IDP=
